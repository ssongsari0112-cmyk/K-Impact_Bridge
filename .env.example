# 이 파일을 .env.local로 복사한 뒤 값을 채우세요. (.env* 는 .gitignore로 제외되어 있습니다)

# ── AI 사업기획서 생성 (src/lib/ai/brief.ts) ──────────────────────────────────
# 프로바이더는 OPENAI_API_KEY > GOOGLE_API_KEY 순으로 선택됩니다.
# 둘 다 없으면 외교부 공공데이터 + 규칙 기반 템플릿으로 초안을 만들고 "데모" 배너를 표시합니다.
OPENAI_API_KEY=
# Structured Outputs를 지원하는 모델이어야 합니다. 기본값: gpt-4.1-mini
# OPENAI_MODEL=gpt-4.1-mini

# ── 기업 프로필 분석 (src/lib/ai/gemini.ts) ───────────────────────────────────
# PDF 회사소개서 분석은 Gemini만 사용합니다. 없으면 mock 프로필로 폴백합니다.
GOOGLE_API_KEY=

# ── 외교부 공공데이터포털 (src/lib/mofa/client.ts) ─────────────────────────────
# 없으면 코드에 내장된 공개 폴백 키를 사용합니다. 실서비스 전환 시 data.go.kr에서 발급받으세요.
MOFA_SERVICE_KEY=

# 모든 AI 경로를 강제로 mock/템플릿으로 돌리려면 true
# NEXT_PUBLIC_FORCE_MOCK=false
